<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>JM Details — Premium Auto Detailing | Miami</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #1E90FF;
      --blue-light: #56AEFF;
      --blue-dim: #1155aa;
      --blue-dark: #0a3d7a;
      --black: #050505;
      --dark: #0e0e0e;
      --dark2: #111418;
      --dark3: #181c22;
      --white: #f0f4ff;
      --gray: #7a8899;
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'Montserrat', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--font-body);
      font-weight: 300;
      overflow-x: hidden;
      font-size: 17px;
    }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--black); }
    ::-webkit-scrollbar-thumb { background: var(--blue-dim); }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 3rem;
      background: linear-gradient(to bottom, rgba(5,5,5,0.98) 0%, transparent 100%);
      transition: background 0.3s;
    }
    nav.scrolled {
      background: rgba(5,5,5,0.97);
      border-bottom: 1px solid rgba(30,144,255,0.2);
    }
    .nav-logo img {
      height: 44px;
      width: auto;
      display: block;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      color: var(--white); text-decoration: none;
      font-size: 0.75rem; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase;
      opacity: 0.7; transition: opacity 0.2s, color 0.2s;
    }
    .nav-links a:hover { opacity: 1; color: var(--blue); }
    .nav-cta {
      background: transparent !important;
      border: 1px solid var(--blue) !important;
      color: var(--blue) !important;
      padding: 0.45rem 1.3rem !important;
      opacity: 1 !important;
      transition: background 0.2s, color 0.2s !important;
    }
    .nav-cta:hover { background: var(--blue) !important; color: var(--black) !important; }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center; position: relative; overflow: hidden;
      padding: 8rem 2rem 4rem;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 70%, rgba(30,144,255,0.09) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 20% 20%, rgba(30,144,255,0.05) 0%, transparent 60%),
        linear-gradient(180deg, #050505 0%, #080c12 50%, #050505 100%);
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(30,144,255,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(30,144,255,0.05) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    }
    .hero-eyebrow {
      font-size: 0.78rem; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--blue); margin-bottom: 1.5rem; position: relative;
      display: flex; align-items: center; gap: 1rem;
      opacity: 0; animation: fadeUp 0.8s 0.2s forwards;
    }
    .hero-eyebrow::before, .hero-eyebrow::after {
      content: ''; width: 40px; height: 1px; background: var(--blue); opacity: 0.5;
    }
    .hero-logo {
      margin-bottom: 1.5rem; position: relative;
      opacity: 0; animation: fadeUp 0.8s 0.1s forwards;
    }
    .hero-logo img {
      height: 80px; width: auto;
      filter: drop-shadow(0 0 20px rgba(30,144,255,0.4));
    }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 300; line-height: 0.95;
      position: relative; opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
    }
    .hero-title em { font-style: italic; color: var(--blue); display: block; }
    .hero-sub {
      margin-top: 1.8rem; font-size: 0.85rem;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gray); position: relative;
      opacity: 0; animation: fadeUp 0.8s 0.6s forwards;
    }
    .hero-actions {
      margin-top: 2.5rem; display: flex; gap: 1.2rem;
      flex-wrap: wrap; justify-content: center;
      position: relative; opacity: 0; animation: fadeUp 0.8s 0.8s forwards;
    }
    .btn-primary {
      background: var(--blue); color: var(--black);
      padding: 0.85rem 2.4rem;
      font-family: var(--font-body); font-size: 0.68rem;
      font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
      text-decoration: none; border: none; cursor: pointer;
      transition: background 0.2s, transform 0.2s; display: inline-block;
    }
    .btn-primary:hover { background: var(--blue-light); transform: translateY(-2px); }
    .btn-secondary {
      background: transparent; color: var(--white);
      padding: 0.85rem 2.4rem;
      font-family: var(--font-body); font-size: 0.68rem;
      font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
      text-decoration: none; border: 1px solid rgba(255,255,255,0.2);
      cursor: pointer; transition: border-color 0.2s, color 0.2s, transform 0.2s;
      display: inline-block;
    }
    .btn-secondary:hover { border-color: var(--blue); color: var(--blue); transform: translateY(-2px); }
    .hero-stats {
      margin-top: 4rem; display: flex; gap: 4rem;
      position: relative; opacity: 0; animation: fadeUp 0.8s 1s forwards;
      flex-wrap: wrap; justify-content: center;
    }
    .stat-num {
      font-family: var(--font-display); font-size: 2.6rem;
      font-weight: 300; color: var(--blue); line-height: 1;
    }
    .stat-label {
      font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gray); margin-top: 0.3rem; text-align: center;
    }
    .scroll-indicator {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
      opacity: 0; animation: fadeUp 0.8s 1.2s forwards;
    }
    .scroll-line {
      width: 1px; height: 50px;
      background: linear-gradient(to bottom, var(--blue), transparent);
      animation: scrollPulse 2s infinite;
    }
    .scroll-text { font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gray); }

    /* ABOUT STRIP */
    .about-strip {
      background: rgba(5,5,5,0.75);
      border-top: 1px solid rgba(30,144,255,0.15);
      border-bottom: 1px solid rgba(30,144,255,0.15);
      padding: 2.5rem 3rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 2rem; flex-wrap: wrap;
    }
    .about-strip-text {
      font-family: var(--font-display); font-size: clamp(1rem, 2vw, 1.3rem);
      font-weight: 300; font-style: italic; color: var(--white); opacity: 0.85;
      max-width: 600px;
    }
    .about-strip-info { display: flex; flex-direction: column; gap: 0.4rem; text-align: right; }
    .about-strip-info p { font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gray); }
    .about-strip-info strong { color: var(--blue); font-weight: 500; }

    /* SECTION BASE */
    section { padding: 6rem 3rem; }
    .section-eyebrow {
      font-size: 0.75rem; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--blue); margin-bottom: 1rem;
      display: flex; align-items: center; gap: 1rem;
    }
    .section-eyebrow::before { content: ''; width: 30px; height: 1px; background: var(--blue); }
    .section-title {
      font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 300; line-height: 1.1; margin-bottom: 1.5rem;
    }
    .section-title em { font-style: italic; color: var(--blue); }

    /* GALLERY */
    .gallery-section { background: var(--dark2); }
    .gallery-grid {
      margin-top: 3rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 3px;
    }
    .gallery-item {
      position: relative; overflow: hidden; cursor: pointer;
      aspect-ratio: 3/4; background: var(--dark3);
    }
    .gallery-item:nth-child(1) { grid-column: span 2; grid-row: span 2; aspect-ratio: unset; }
    .gallery-item:nth-child(7) { grid-column: span 2; aspect-ratio: unset; min-height: 220px; }
    .gallery-item img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.5s ease;
      display: block;
    }
    .gallery-item:hover img { transform: scale(1.05); }
    .gallery-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(5,5,5,0.9) 0%, transparent 100%);
      padding: 1.2rem; opacity: 0; transition: opacity 0.3s;
      display: flex; flex-direction: column; gap: 0.2rem;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }
    .gallery-car { font-size: 0.9rem; font-weight: 600; color: var(--white); }
    .gallery-service { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--blue); }

    /* LIGHTBOX */
    .lightbox {
      display: none; position: fixed; inset: 0; z-index: 999;
      background: rgba(0,0,0,0.95); align-items: center; justify-content: center;
      flex-direction: column; gap: 1rem;
    }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 90vw; max-height: 80vh; object-fit: contain; }
    .lightbox-caption { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blue); }
    .lightbox-close {
      position: absolute; top: 1.5rem; right: 2rem;
      font-size: 1.5rem; color: var(--white); cursor: pointer; opacity: 0.7;
      background: none; border: none;
    }
    .lightbox-close:hover { opacity: 1; }

    /* SERVICES */
    .services-section { background: var(--black); }
    .service-cards {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5px; background: transparent; margin-top: 3rem;
    }
    .service-card {
      background: rgba(5,5,5,0.72); backdrop-filter: blur(4px); padding: 2.5rem;
      border: 1px solid rgba(30,144,255,0.15);
      position: relative; overflow: hidden; transition: background 0.3s;
    }
    .service-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--blue); transform: scaleX(0); transform-origin: left; transition: transform 0.4s;
    }
    .service-card:hover { background: rgba(10,15,25,0.82); }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card-tag { font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; }
    .service-card-name { font-family: var(--font-display); font-size: 1.6rem; font-weight: 400; margin-bottom: 0.5rem; }
    .service-card-desc { font-size: 0.82rem; line-height: 1.7; color: var(--gray); margin-bottom: 1.5rem; }
    .service-card-includes { margin-bottom: 1.8rem; }
    .service-card-includes h4 { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blue-dim); margin-bottom: 0.7rem; }
    .service-card-includes ul { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
    .service-card-includes li { font-size: 0.82rem; color: var(--gray); padding-left: 1rem; position: relative; }
    .service-card-includes li::before { content: '—'; position: absolute; left: 0; color: var(--blue); opacity: 0.5; }
    .service-card-prices {
      display: flex; gap: 1.5rem;
      padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.07);
    }
    .price-label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gray); margin-bottom: 0.2rem; }
    .price-amount { font-family: var(--font-display); font-size: 1.8rem; font-weight: 300; color: var(--blue); }

    /* ADDONS */
    .addons-section { background: var(--dark2); }
    .addons-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1px; background: transparent; margin-top: 3rem;
    }
    .addon-item { background: rgba(5,5,5,0.70); backdrop-filter: blur(4px); border: 1px solid rgba(30,144,255,0.12); padding: 1.8rem; transition: background 0.2s; }
    .addon-item:hover { background: rgba(10,15,25,0.82); }
    .addon-name { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.5rem; color: var(--white); }
    .addon-desc { font-size: 0.78rem; color: var(--gray); line-height: 1.6; margin-bottom: 1rem; }
    .addon-price { font-family: var(--font-display); font-size: 1.7rem; color: var(--blue); }

    /* PAINT CORRECTION */
    .paint-section { background: var(--black); }
    .paint-package {
      background: rgba(5,5,5,0.72); backdrop-filter: blur(4px); border: 1px solid rgba(30,144,255,0.2);
      padding: 3rem; margin-bottom: 1.5px;
    }
    .paint-package.featured {
      border-color: rgba(30,144,255,0.45);
      background: rgba(5,10,25,0.78);
    }
    .paint-package-badge {
      position: absolute; top: 1.5rem; right: 1.5rem;
      font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--black); background: var(--blue); padding: 0.3rem 0.8rem;
    }
    .paint-package { position: relative; }
    .paint-package-name { font-family: var(--font-display); font-size: 1.8rem; font-weight: 300; margin-bottom: 0.5rem; }
    .paint-package-sub { font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.5rem; }
    .paint-includes { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
    .paint-tag { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--gray); border: 1px solid rgba(255,255,255,0.1); padding: 0.3rem 0.7rem; }
    .paint-pricing {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: rgba(30,144,255,0.15); max-width: 600px;
    }
    .paint-price-cell { background: rgba(5,5,5,0.65); padding: 1.2rem 1.5rem; }
    .paint-price-cell.header {
      background: rgba(30,144,255,0.18); font-size: 0.75rem;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--blue);
      display: flex; align-items: center;
    }
    .paint-price-cell .vehicle { font-size: 0.78rem; color: var(--gray); margin-bottom: 0.3rem; }
    .paint-price-cell .amount { font-family: var(--font-display); font-size: 1.7rem; color: var(--white); }

    /* REVIEWS */
    .reviews-section { background: var(--dark2); overflow: hidden; }
    .reviews-track-outer { overflow: hidden; margin-top: 3rem; }
    .reviews-track {
      display: flex; gap: 1.5rem;
      animation: slide 40s linear infinite; width: max-content;
    }
    .reviews-track:hover { animation-play-state: paused; }
    .review-card {
      background: rgba(5,5,5,0.75); backdrop-filter: blur(4px); border: 1px solid rgba(30,144,255,0.18);
      padding: 2rem; width: 300px; flex-shrink: 0; transition: border-color 0.2s;
    }
    .review-card:hover { border-color: rgba(30,144,255,0.4); }
    .review-stars { color: var(--blue); font-size: 0.7rem; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .review-text {
      font-family: var(--font-display); font-size: 1.05rem;
      line-height: 1.75; color: rgba(240,244,255,0.75);
      margin-bottom: 1.5rem; font-style: italic;
    }
    .review-author { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--blue); }

    /* INFO SECTION */
    .info-section {
      background: var(--black);
      display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    }
    .info-col {
      padding: 5rem 3rem;
      background: rgba(5,5,5,0.72); backdrop-filter: blur(4px);
      border-right: 1px solid rgba(30,144,255,0.1);
    }
    .info-col:last-child { border-right: none; }
    .hours-list { margin-top: 2rem; display: flex; flex-direction: column; }
    .hours-row {
      display: flex; justify-content: space-between;
      padding: 0.85rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.88rem;
    }
    .hours-row .day { color: var(--white); font-weight: 500; letter-spacing: 0.05em; }
    .hours-row .time { color: var(--blue-light); font-weight: 400; }
    .hours-row.closed .time { color: var(--gray); }
    .contact-items { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.5rem; }
    .contact-label { font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.4rem; }
    .contact-value { font-size: 1rem; color: var(--white); }
    .contact-value a { color: var(--white); text-decoration: none; transition: color 0.2s; }
    .contact-value a:hover { color: var(--blue); }
    .social-links { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }
    .social-link {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gray); text-decoration: none;
      border: 1px solid rgba(255,255,255,0.1); padding: 0.6rem 1.2rem;
      transition: border-color 0.2s, color 0.2s;
    }
    .social-link:hover { border-color: var(--blue); color: var(--blue); }

    /* CTA */
    .cta-banner { background: var(--blue); padding: 4rem; text-align: center; }
    .cta-banner h2 {
      font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300; color: var(--black); margin-bottom: 0.5rem;
    }
    .cta-banner h2 em { font-style: italic; }
    .cta-banner p { font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(5,5,5,0.6); margin-bottom: 2rem; }
    .btn-dark {
      background: var(--black); color: var(--blue);
      padding: 0.9rem 2.5rem; font-family: var(--font-body);
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
      text-decoration: none; border: none; cursor: pointer;
      transition: background 0.2s, transform 0.2s; display: inline-block;
    }
    .btn-dark:hover { background: #0a0a0a; transform: translateY(-2px); }

    /* FOOTER */
    footer {
      background: var(--black); border-top: 1px solid rgba(30,144,255,0.1);
      padding: 2rem 3rem; display: flex; justify-content: space-between;
      align-items: center; flex-wrap: wrap; gap: 1rem;
    }
    .footer-logo img { height: 32px; width: auto; }
    .footer-copy { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--gray); }
    .footer-area { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray); }

    /* ANIMATIONS */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes scrollPulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }
    @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s, transform 0.7s; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 900px) {
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .gallery-item:nth-child(1) { grid-column: span 2; min-height: 260px; }
      .gallery-item:nth-child(7) { grid-column: span 1; }
    }
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      section { padding: 4rem 1.5rem; }
      .about-strip { padding: 2rem 1.5rem; }
      .about-strip-info { text-align: left; }
      .info-section { grid-template-columns: 1fr; }
      .info-col { padding: 3rem 1.5rem; border-right: none; border-bottom: 1px solid rgba(30,144,255,0.1); }
      .cta-banner { padding: 3rem 1.5rem; }
      footer { padding: 1.5rem; flex-direction: column; text-align: center; }
      .hero-stats { gap: 2rem; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 2px; }
      .gallery-item:nth-child(1) { grid-column: span 2; min-height: 220px; }
    }
  
    /* INTERACTIVE SERVICE CARDS */
    .service-card {
      cursor: pointer;
      transform: translateY(0);
      transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
    }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 60px rgba(30,144,255,0.15);
    }
    .service-card.expanded {
      transform: translateY(-6px);
      box-shadow: 0 20px 60px rgba(30,144,255,0.25);
      border-color: rgba(30,144,255,0.5) !important;
      background: rgba(5,15,35,0.88) !important;
    }
    .service-card-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.4s ease;
      opacity: 0;
    }
    .service-card.expanded .service-card-body {
      max-height: 600px;
      opacity: 1;
    }
    .service-card-preview {
      transition: opacity 0.3s;
    }
    .service-card.expanded .service-card-preview {
      display: none;
    }
    .service-card-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.5rem;
    }
    .toggle-icon {
      width: 32px; height: 32px;
